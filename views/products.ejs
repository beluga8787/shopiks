<%- include('assets/top') %>

<h2>Products</h2>

<div class="products">
    <% if (products.length == 0) { %>
        <p class="no-products">No products yet</p>
    <%} else { %>
        <% for(const prod of products) { %>
        <div class="card">
            <img src="<%= prod.image %>" alt="<%= prod.name %>" class="card-img">
            <div class="card-elements">
                <p class="card-title"><%= prod.name %></p>
                <p class="card-price"><%= prod.price %></p>
                <button class="card-add">+</button>
            </div>
        </div>
        <% } %>
    <% } %>
</div>

